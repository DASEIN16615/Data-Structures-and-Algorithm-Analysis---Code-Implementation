void Shellsort(int*a,int n)
{
    int i,j,increment;
    int temp;
    for(increment=n/2;increment>0;increment/=2)
    {
        for(i=increment;i<n;i++)
        {
            temp=a[i];
            for(j=i;j>=increment;j-=increment)
                if(temp<a[j-increment])
                a[j]=a[j-increment];
            else
                break;
                a[j]=temp;
        }
    }
    array_print(a,n);
}
