void my_insertion_sort(int*a,int n)
{
    for(int i=0;i<n;i++)
    {
        for(int j=i-1;j>=0;j--)
        {
            if(a[i]<a[j])
            {
                int temp=a[i];
                for(int k=i;k>j;k--)
                {
                    a[k]=a[k-1];
                }
                a[j]=temp;

            }
        }
    }
    array_print(a,n);
}
void InsertionSort(int *a,int n)
{
    int j,p;
    int temp;
    for(p=1;p<n;p++)
    {
        temp=a[p];
        for(j=p;j>0&&a[j-1]>temp;j--)//合并了两步
            a[j]=a[j-1];
        a[j]=temp;
    }
    array_print(a,n);
}

void array_print(int *a,int n)
{
    for(int i=0;i<n;i++)
        printf("%3d",*(a+i));
    printf("\n");
}
