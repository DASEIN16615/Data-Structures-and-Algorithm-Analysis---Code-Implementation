    ThisSum=MaxSum=0;
    for(j=0;j<N;j++)
    {
        if(ThisSum>MaxSum)
            MaxSum=ThisSum;
        else if(ThisSum<0)
            ThisSum=0;
    }
    printf("testbook solution4 is %d",MaxSum);
}
