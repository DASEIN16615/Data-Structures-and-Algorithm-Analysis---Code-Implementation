#include<stdio.h>

long int  pow(long int x,unsigned int n);
int iseven(unsigned int n);
int  main()
{
    long int x;
    unsigned int n;
    printf("Enter the base and exponent: ");
    scanf("%ld %u",&x,&n);
    printf("%ld^%u = %ld\n",x,n,pow(x,n));
    return 0;
}

long int  pow(long int x,unsigned int n)
{
    if(n==0)
        return 1;
    if(n==1)
        return x;
    if(iseven(n))
        return pow(x*x,n/2);
    else
        return pow(x*x,n/2)*x;
}
 int iseven(unsigned int n)
 {
     return n%2==0;
 }
