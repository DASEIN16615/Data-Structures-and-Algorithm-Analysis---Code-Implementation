#include<stdio.h>
#include<stdlib.h>


void array_print(int *a,int n);
void Erastothenes(int *a,int n);//Erastothenes筛

int main()
{
    int n;
    printf("please input n\n");
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++)
        a[i]=i+1;
    Erastothenes(a,n);
      return 0;
}

void Erastothenes(int a[],int n)
{
    for(int i=2;i<=(n/2);i++)
    {
        for(int k=0;k<n;k++)
        {
            if(a[k]%i==0)
            a[k]=-1;
        }
    }
    for(int i=0;i<n;i++)
        if(a[i]>0)
        printf("%3d",a[i]);
}
void array_print(int *a,int n)
{
    for(int i=0;i<n;i++)
        printf("%d",a[i]);
        printf("\n");
}
