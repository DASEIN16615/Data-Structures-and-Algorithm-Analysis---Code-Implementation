#include<stdio.h>
#include<stdlib.h>
#include<stdbool.h>

// 队列ADT的数组实现
struct Queue* createQueue(int maxElements);
bool isEmpty(struct Queue* q);
bool isFull(struct Queue* q);
void disposeQueue(struct Queue* q); // 释放队列内存空间
void makeEmpty(struct Queue* q);
void enqueue(int x, struct Queue* q);
void dequeue(struct Queue* q);
int succ(int index, struct Queue* q); // 循环数组的角标计算
int front(struct Queue* q);
int frontAndDequeue(struct Queue* q);
void printQueue(struct Queue* q);

// 队列结构体定义
struct Queue {
    int capacity; // 队列的容量
    int size;     // 队列有效数据的大小
    int front;    // 队头的角标
    int rear;     // 队尾的角标
    int *array;   // 指向数组首元素的地址
};

int main()
{
    int val;
    struct Queue* q;

    // 创建容量为5的队列
    q = createQueue(5);

    // 入队操作
    enqueue(1, q);
    enqueue(2, q);
    enqueue(3, q);
    enqueue(4, q);
    enqueue(5, q);

    // 打印队列内容
    printQueue(q);
    printf("-=-=-=-=-=-=-=-=-=-=-=-=-=-=\n");

    // 出队操作（移除前两个元素）
    dequeue(q);
    dequeue(q);

    // 入队新元素
    enqueue(9, q);

    // 打印队列内容
    printQueue(q);
    printf("-=-=-=-=-=-=-=-=-=-=-=-=-=-=\n");

    // 获取队头元素
    val = front(q);
    printf("val: %d\n", val);
    printf("-=-=-=-=-=-=-=-=-=-=-=-=-=-=\n");

    // 释放队列内存
    disposeQueue(q);
    return 0;
}

// 创建队列
struct Queue* createQueue(int maxElements)
{
    struct Queue* q = (struct Queue*)malloc(sizeof(struct Queue));
    if(q == NULL)
    {
        printf("out of space!\n");
        return NULL;
    }

    q->array = (int*)malloc(sizeof(int) * maxElements);
    if(q->array == NULL)
    {
        printf("out of space!\n");
        free(q);
        return NULL;
    }

    q->capacity = maxElements;
    makeEmpty(q);
    return q;
}

// 检查队列是否为空
bool isEmpty(struct Queue* q)
{
    return q->size == 0;
}

// 检查队列是否已满
bool isFull(struct Queue* q)
{
    return q->size == q->capacity;
}

// 释放队列内存空间
void disposeQueue(struct Queue* q)
{
    free(q->array);
    free(q);
}

// 清空队列
void makeEmpty(struct Queue* q)
{
    q->size = 0;
    q->front = 1;  // 初始化front为1，rear为0，确保front != rear
    q->rear = 0;
}

// 从队尾入队元素x
void enqueue(int x, struct Queue* q)
{
    if(isFull(q))
    {
        printf("full queue\n");
        return;
    }
    else
    {
        q->size++;
        q->rear = succ(q->rear, q);
        q->array[q->rear] = x;
    }
}

// 从队头出队
void dequeue(struct Queue* q)
{
    if(isEmpty(q))
    {
        printf("empty queue\n");
        return;
    }
    else
    {
        q->size--;
        q->front = succ(q->front, q);
    }
}

// 循环数组的角标计算（解决循环队列中索引越界问题）
int succ(int index, struct Queue* q)
{
    return (index + 1) % q->capacity;
}

// 获取队头元素（不移除）
int front(struct Queue* q)
{
    if(isEmpty(q))
    {
        printf("empty queue\n");
        return -1; // 返回错误值
    }
    else
    {
        return q->array[q->front];
    }
}

// 获取队头元素并移除
int frontAndDequeue(struct Queue* q)
{
    int value = front(q);
    dequeue(q);
    return value;
}

// 打印队列内容
void printQueue(struct Queue* q)
{
    int i;
    int front = q->front;
    int size = q->size;
    int capacity = q->capacity;

    for(i = 0; i < size; i++)
    {
        printf("element is:%d\n", q->array[(front + i) % capacity]);
    }
}
