#include<stdio.h>

void Euclidean (int a, int b);

int  main()
{
    printf("Enter two integers: ");
    int a, b;
    scanf("%d %d", &a, &b);
    Euclidean (a, b);
    return 0;
}
void Euclidean (int a, int b)
{
    while(b != 0)
    {
        int temp = b;
        b = a % b;
        a = temp;
    }
    printf("GCD is: %d\n", a);
}
